# Supabase Project Connection Credentials
# Copy this file to .env or .env.local and fill in your values.

# The API URL of your Supabase project (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# The client/anonymous public key (found in Project Settings > API)
# Safe to expose in the frontend, respects Row Level Security (RLS)
SUPABASE_ANON_KEY=your-anon-key-here

# The service role secret key (found in Project Settings > API)
# WARNING: NEVER expose this on the frontend. It bypasses RLS policies.
# Use only in secure backend environments (edge functions, server APIs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PostgreSQL connection string for direct database access (Project Settings > Database)
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://postgres.your-project-id:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
